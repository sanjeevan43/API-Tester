{
  "name": "api-sentinel-vsc",
  "displayName": "API Sentinel — Automated API Testing",
  "description": "Automatically detect, generate, execute, and display API tests inside VS Code.",
  "version": "3.2.0",
  "publisher": "sanjeevan43",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "api",
    "testing",
    "rest",
    "http",
    "express",
    "django",
    "flask",
    "vapor"
  ],
  "icon": "media/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apiSentinel.runAll",
        "title": "API Sentinel: Run All Tests",
        "icon": "$(play)"
      },
      {
        "command": "apiSentinel.scanProject",
        "title": "API Sentinel: Scan Project for Endpoints",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apiSentinel.scanProject",
          "when": "view == apiSentinel.endpointSidebar",
          "group": "navigation@1"
        },
        {
          "command": "apiSentinel.runAll",
          "when": "view == apiSentinel.endpointSidebar",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apiSentinel",
          "title": "API Sentinel",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "apiSentinel": [
        {
          "type": "webview",
          "id": "apiSentinel.endpointSidebar",
          "name": "Sentinel Pro Dashboard",
          "icon": "media/icon.png"
        },
        {
          "type": "webview",
          "id": "apiSentinel.settingsView",
          "name": "Settings",
          "icon": "media/icon.png"
        }
      ]
    },
    "configuration": {
      "title": "API Sentinel",
      "properties": {
        "apiSentinel.baseURL": {
          "type": "string",
          "default": "",
          "description": "Base URL of the API server"
        },
        "apiSentinel.apiKey": {
          "type": "string",
          "default": "",
          "description": "Authorization token or API key"
        },
        "apiSentinel.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Request timeout in milliseconds"
        },
        "apiSentinel.retries": {
          "type": "number",
          "default": 0,
          "description": "Number of times to retry failed requests"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sanjeevan43/API-Tester"
  },
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "glob": "^10.3.10",
    "uuid": "^9.0.1"
  }
}
